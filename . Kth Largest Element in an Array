

class Solution {
public:
    string findSum(string a, string b) {

        int i = a.size() - 1;
        int j = b.size() - 1;

        int carry = 0;
        string ans = "";

        while (i >= 0 || j >= 0 || carry) {

            int sum = carry;

            if (i >= 0)
                sum += a[i--] - '0';

            if (j >= 0)
                sum += b[j--] - '0';

            ans.push_back((sum % 10) + '0');
            carry = sum / 10;
        }

        reverse(ans.begin(), ans.end());

        int k = 0;
        while (k < ans.size() - 1 && ans[k] == '0')
            k++;

        return ans.substr(k);
    }

    string minSum(vector<int> &arr) {

        sort(arr.begin(), arr.end());

        string num1 = "", num2 = "";

        for (int i = 0; i < arr.size(); i++) {
            if (i % 2 == 0)
                num1 += (arr[i] + '0');
            else
                num2 += (arr[i] + '0');
        }

        return findSum(num1, num2);
    }
};

Example 1:

Input: nums = [3,2,1,5,6,4], k = 2
Output: 5
Example 2:

Input: nums = [3,2,3,1,2,4,5,5,6], k = 4
Output: 4
 
