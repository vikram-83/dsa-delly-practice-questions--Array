#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    vector<int> generateNextPalindrome(vector<int>& arr) {
        int n = arr.size();
        
        // --- CASE 1: All 9s ---
        bool all9s = true;
        for (int x : arr) {
            if (x != 9) {
                all9s = false;
                break;
            }
        }
        if (all9s) {
            vector<int> ans(n + 1, 0);
            ans[0] = 1;
            ans[n] = 1;
            return ans;
        }

        // --- GENERAL CASES ---
        int mid = n / 2;
        int i = mid - 1;
        // If n is odd, j starts after the middle element; if even, j starts at mid
        int j = (n % 2 == 0) ? mid : mid + 1;

        // Skip digits that are already identical in the left and right halves
        while (i >= 0 && arr[i] == arr[j]) {
            i--;
            j++;
        }

        bool leftSmaller = false;
        // If we reached the bounds, it means the input is already a palindrome
        if (i < 0 || arr[i] < arr[j]) {
            leftSmaller = true;
        }

        // Mirror the left half to the right half initially
        i = mid - 1;
        j = (n % 2 == 0) ? mid : mid + 1;
        while (i >= 0) {
            arr[j] = arr[i];
            i--;
            j++;
        }

        // --- CASE 2: Left half mirrored was smaller or equal ---
        // We must increment from the middle and handle carries
        if (leftSmaller) {
            int carry = 1;
            i = mid - 1;
            
            // If n is odd, the true middle element must be handled first
            if (n % 2 != 0) {
                arr[mid] += carry;
                carry = arr[mid] / 10;
                arr[mid] %= 10;
                j = mid + 1;
            } else {
                j = mid;
            }

            // Propagate carry outwards symmetrically
            while (i >= 0 && carry > 0) {
                arr[i] += carry;
                carry = arr[i] / 10;
                arr[i] %= 10;
                arr[j] = arr[i]; // Keep it palindromic
                i--;
                j++;
            }
        }

        return arr;
    }
};

Given a number, in the form of an array arr[] containing digits from 1 to 9(inclusive). Find the next smallest palindrome strictly larger than the given number.

Examples:

Input: arr[] = [9, 4, 1, 8, 7, 9, 7, 8, 3, 2, 2]
Output: [9, 4, 1, 8, 8, 0, 8, 8, 1, 4, 9]
Explanation: Next smallest palindrome is 9 4 1 8 8 0 8 8 1 4 9.
