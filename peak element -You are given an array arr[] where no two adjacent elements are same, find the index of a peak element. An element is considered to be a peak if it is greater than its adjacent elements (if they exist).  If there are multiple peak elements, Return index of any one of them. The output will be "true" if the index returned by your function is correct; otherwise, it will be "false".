class Solution {
public:
    int peakElement(vector<int> &arr) {

        int n = arr.size();

        for (int i = 0; i < n; i++) {

            bool left = (i == 0) || (arr[i] > arr[i - 1]);

            bool right = (i == n - 1) || (arr[i] > arr[i + 1]);

            if (left && right) {
                return i;
            }
        }

        return -1;
    }
};
Input: arr = [1, 2, 4, 5, 7, 8, 3]
Output: true
Explanation: arr[5] = 8 is a peak element because arr[4] < arr[5] > arr[6].
